# Application Configuration
APP_NAME=Bionex API
APP_VERSION=1.0.0
DEBUG=true

# JWT Security (MUST BE SET - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=CHANGE_ME_TO_SECURE_RANDOM_VALUE_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Sharing sessions (NFC / Bluetooth)
SHARING_TOKEN_EXPIRE_MINUTES=30

# Database (configured for Docker Compose)
DATABASE_URL=postgresql://bionex:bionex@postgres:5432/bionex

# Field-level encryption (MUST BE SET - Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=CHANGE_ME_TO_FERNET_KEY_IN_PRODUCTION

# Redis (configured for Docker Compose)
REDIS_URL=redis://redis:6379/0

# CORS - comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting
RATE_LIMIT_AUTH=30/minute
RATE_LIMIT_DEFAULT=1000/minute
RATE_LIMIT_SENSITIVE=5/minute

# Enhanced Security Settings
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_EXPIRY_DAYS=90
PASSWORD_REUSE_COUNT=5

# Session Management
SESSION_TIMEOUT_MINUTES=30
SESSION_TIMEOUT_DOCTOR_MINUTES=120

# Admin IP Whitelisting
ADMIN_IP_WHITELIST=

# ───────────────────────────────────────────────────────────────────────────
# Phase 1: Encryption Infrastructure
# ───────────────────────────────────────────────────────────────────────────

# Cryptographic Algorithms Configuration
CRYPTO_ALGORITHM=ECDH_P256                    # Key exchange algorithm
CRYPTO_HASH=SHA256                            # Cryptographic hash
CRYPTO_CIPHER=CHACHA20_POLY1305               # Symmetric cipher

# Session Key Management
SESSION_KEY_TTL_DAYS=7                        # Session key validity in days
SESSION_KEY_TTL_MINUTES=60                    # For testing scenarios

# Key Rotation Policy
KEY_ROTATION_DAYS=90                          # Rotate keys every N days

# HashiCorp Vault Configuration (Secrets Management)
# For local development, use: vault server -dev
# For production, use HA cluster with proper auth methods
VAULT_ADDR=http://localhost:8200              # Vault server address
VAULT_TOKEN=                                  # Vault authentication token
VAULT_NAMESPACE=bionex                        # Namespace for secrets
VAULT_SKIP_VERIFY=False                       # NEVER set to True in production