# Application Configuration
APP_NAME=Bionex API
APP_VERSION=1.0.0
DEBUG=true

# JWT Security (MUST BE SET - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=CHANGE_ME_TO_SECURE_RANDOM_VALUE_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Sharing sessions (NFC / Bluetooth)
SHARING_TOKEN_EXPIRE_MINUTES=30

# Database (configured for Docker Compose)
DATABASE_URL=postgresql://bionex:bionex@postgres:5432/bionex

# Field-level encryption (MUST BE SET - Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=CHANGE_ME_TO_FERNET_KEY_IN_PRODUCTION

# Redis (configured for Docker Compose)
REDIS_URL=redis://redis:6379/0

# CORS - comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting
RATE_LIMIT_AUTH=30/minute
RATE_LIMIT_DEFAULT=1000/minute